<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SourceGit.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SourceGit.Views.DashboardToolbar"
             x:DataType="vm:Dashboard">
  <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,0">
    <StackPanel Grid.Column="0" Orientation="Horizontal">
      <TextBlock Text="Repositories"
                 FontWeight="Bold"
                 VerticalAlignment="Center"
                 Margin="4,0,0,0"/>
    </StackPanel>

    <StackPanel Grid.Column="2" Orientation="Horizontal">
      <Button Classes="icon_button" Width="32" Click="OnAddRepository" ToolTip.Tip="Add Repository">
        <Path Width="14" Height="14" Margin="0,2,0,0" Data="{StaticResource Icons.Folder.Open}"/>
      </Button>

      <Button Classes="icon_button" Width="32" Click="OnScanFolder" ToolTip.Tip="Scan Folder for Repositories">
        <Path Width="14" Height="14" Data="{StaticResource Icons.Scan}"/>
      </Button>

      <Button Classes="icon_button" Width="32" Click="OnRefreshClicked" ToolTip.Tip="Refresh">
        <Path Width="14" Height="14" Data="{StaticResource Icons.Loading}"/>
      </Button>
    </StackPanel>
  </Grid>
</UserControl>
